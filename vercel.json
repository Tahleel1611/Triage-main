{
      "builds": [
              {
                        "src": "src/backend/main.py",
                        "use": "@vercel/python",
                        "config": { "requirementsFile": "requirements-vercel.txt" }
                      }
            ],
      "routes": [
              {
                        "src": "/(.*)",
                        "dest": "src/backend/main.py"
                      }
            ]
    }
